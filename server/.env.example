# Backend Environment Variables Template
# Copy this file to .env and fill in the values

# Supabase Configuration (get from Supabase project settings)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Database Configuration (optional, if using direct DB connection)
DATABASE_URL=postgresql://user:password@localhost:5432/cy_sentinel

# API Keys (optional, for external services)
STRIPE_SECRET_KEY=your_stripe_secret_key

# Logging
LOG_LEVEL=info
